{
  "name": "iracing-incident-spotter",
  "version": "0.1.9",
  "description": "Standalone desktop tool for broadcasters: live incident feed + replay jump, reads iRacing SDK directly.",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-irsdk-2023": "^2.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.spotter.iracing",
    "productName": "iRacing Incident Spotter",
    "directories": { "output": "dist-electron" },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "iRacing-Incident-Spotter-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "iRacing Incident Spotter"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "TNrockytop21",
        "repo": "iracing-incident-spotter"
      }
    ]
  }
}
